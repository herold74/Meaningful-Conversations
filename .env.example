# This is an example file. For local development, copy this to a new file 
# named .env and fill in the correct values for your environment.

# NOTE: Environment variables for Vite must start with VITE_

# URL for the live production backend
VITE_BACKEND_URL_PRODUCTION="https://your-production-backend-url.run.app"

# URL for the staging/testing backend
VITE_BACKEND_URL_STAGING="https://your-staging-backend-url.run.app"

# URL for the local development backend
VITE_BACKEND_URL_LOCAL="http://localhost:3001"

# --- RevenueCat (iOS In-App Purchases) ---
# Get this from RevenueCat Dashboard → Project → API Keys → iOS
VITE_REVENUECAT_IOS_KEY="YOUR_REVENUECAT_IOS_API_KEY"

# --- Branding / White-Label (optional) ---
# Override any of these to rebrand the frontend. Defaults match "Meaningful Conversations"
# with the manualmode.at teal palette. See DOCUMENTATION/WHITE-LABEL-GUIDE.md for details.
# Pre-built brand configs are available in brands/*.env (copy values into your .env).
#VITE_BRAND_APP_NAME="Meaningful Conversations"
#VITE_BRAND_APP_NAME_DE="Sinnstiftende Gespräche"
#VITE_BRAND_SHORT_NAME="Meaningful"
#VITE_BRAND_PROVIDER_NAME="manualmode.at"
#VITE_BRAND_PROVIDER_URL="https://www.manualmode.at"
#VITE_BRAND_CONTACT_EMAIL="gherold@manualmode.at"
#VITE_BRAND_OWNER_NAME="Günter Herold"
#VITE_BRAND_PRIMARY_COLOR="#1B7272"
#VITE_BRAND_PRIMARY_COLOR_DARK="#165a5a"
#VITE_BRAND_COLOR_1="#5BBFBF"
#VITE_BRAND_COLOR_2="#3D9E9E"
#VITE_BRAND_COLOR_3="#1B7272"
#VITE_BRAND_COLOR_4="#165a5a"
#VITE_BRAND_ACCENT="#F59E0B"
#VITE_BRAND_LOADER="steering-wheel"
#VITE_BRAND_DOMAIN_STAGING="mc-beta.manualmode.at"
#VITE_BRAND_DOMAIN_PRODUCTION="mc-app.manualmode.at"
#VITE_BRAND_APP_URL_PRODUCTION="https://mc-app.manualmode.at"
#VITE_BRAND_SERVER_IP=""  # Server IP for direct-IP fallback in api.ts (leave empty if not needed)