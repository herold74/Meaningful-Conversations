# manualmode.at Brand Configuration
# Color palette based on manualmode.at schema (Teal/Petrol + warm accent).
# Copy to .env.local to use: cp brands/manualmode.env .env.local
# See DOCUMENTATION/WHITE-LABEL-GUIDE.md for details.

# --- Identity ---
VITE_BRAND_APP_NAME="Meaningful Conversations"
VITE_BRAND_APP_NAME_DE="Sinnstiftende Gespräche"
VITE_BRAND_SHORT_NAME="Meaningful"
VITE_BRAND_PROVIDER_NAME="manualmode.at"
VITE_BRAND_PROVIDER_URL="https://www.manualmode.at"
VITE_BRAND_CONTACT_EMAIL="support@manualmode.at"
VITE_BRAND_OWNER_NAME="Günter Herold"

# --- Color Palette (4-shade gradient, lightest to darkest) ---
# Schema: Light Cyan → Light Blue-Grey → Dark Teal → Dark Blue
VITE_BRAND_COLOR_1="#80E3EE"
VITE_BRAND_COLOR_2="#9ABACF"
VITE_BRAND_COLOR_3="#2D5F6E"
VITE_BRAND_COLOR_4="#335496"
# Accent: Light Orange / Peach
VITE_BRAND_ACCENT="#F0C888"
VITE_BRAND_PRIMARY_COLOR="#2D5F6E"
VITE_BRAND_PRIMARY_COLOR_DARK="#254a5a"

# --- Loader ---
VITE_BRAND_LOADER="steering-wheel"

# --- Domains ---
VITE_BRAND_DOMAIN_STAGING="mc-beta.manualmode.at"
VITE_BRAND_DOMAIN_PRODUCTION="mc-app.manualmode.at"
VITE_BRAND_APP_URL_PRODUCTION="https://mc-app.manualmode.at"
